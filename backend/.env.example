# Copy this file to .env and fill in real values. Never commit the real .env file.

# Port your Express server runs on locally
PORT=5000

# MongoDB Atlas connection string (get this from Atlas after creating a free cluster)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/reservationDB?retryWrites=true&w=majority

# Any long random string - used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# How long a login token stays valid
JWT_EXPIRES_IN=7d
